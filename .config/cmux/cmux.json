{
  "commands": [
    {
      "name": "Claude (Maze)",
      "keywords": [
        "claude",
        "maze"
      ],
      "command": "caffeinate claude",
      "confirm": false
    },
    {
      "name": "Claude (Personal)",
      "keywords": [
        "claude",
        "personal"
      ],
      "command": "CLAUDE_CONFIG_DIR=~/.claude-personal caffeinate claude",
      "confirm": false
    },
    {
      "name": "Tilt",
      "keywords": [
        "tilt"
      ],
      "command": "cd \"$(git rev-parse --show-toplevel)\" && tilt up",
      "confirm": false
    },
    {
      "name": "Prisma Migrate Deploy (Moderated)",
      "keywords": [
        "prisma",
        "migrate",
        "deploy",
        "moderated"
      ],
      "command": "cd \"$(git rev-parse --show-toplevel)/services/service-moderated-testing\" && pnpm prisma migrate deploy",
      "confirm": false
    },
    {
      "name": "Monorepo Tunnels",
      "keywords": [
        "tunnels",
        "monorepo",
        "cloudflared"
      ],
      "command": "cloudflared tunnel --config /Users/ross/projects/maze/tunnels/config.yml run",
      "confirm": false
    },
    {
      "name": "Monorepo Dev",
      "keywords": [
        "monorepo",
        "dev"
      ],
      "restart": "confirm",
      "workspace": {
        "name": "Monorepo Dev",
        "cwd": "~/projects/maze/maze-monorepo",
        "layout": {
          "direction": "vertical",
          "split": 0.3,
          "children": [
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "Tilt",
                    "command": "tilt up",
                    "focus": true
                  }
                ]
              }
            },
            {
              "pane": {
                "surfaces": [
                  {
                    "type": "terminal",
                    "name": "Tunnels",
                    "command": "cloudflared tunnel --config /Users/ross/projects/maze/tunnels/config.yml run"
                  }
                ]
              }
            }
          ]
        }
      }
    },
